# Application Settings
APP_NAME="DataScope AI"
APP_VERSION="1.0.0"
APP_ENV=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=9000

# Database Configuration
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/datascope_ai
DATABASE_TEST_URL=postgresql+psycopg://postgres:postgres@localhost:5432/datascope_ai_test

# Security & Authentication
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174

# Redis Configuration (for Celery & Cache)
REDIS_URL=redis://localhost:6379/0

# Scraping Configuration
SCRAPY_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
SCRAPING_DELAY=1
CONCURRENT_REQUESTS=8

# API Keys (Add your own)
GITHUB_API_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
OPENAI_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/datascope.log
